{%- comment -%}
  layout/theme.liquid — Skystar Tour and Travels
  Production-ready main layout for Shopify Dawn theme.
  Includes: Google Fonts, CSS/JS assets, SEO meta, structured data,
  announcement bar, sticky header, floating WhatsApp button, footer.
{%- endcomment -%}
<!doctype html>
<html
  lang="{{ request.locale.iso_code }}"
  dir="{% if request.locale.iso_code == 'ar' or request.locale.iso_code == 'he' %}rtl{% else %}ltr{% endif %}"
>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">

  {%- comment -%} SEO Meta Tags {%- endcomment -%}
  <title>
    {%- if page_title == shop.name -%}
      {{ shop.name }} — {{ settings.store_tagline | default: 'Your Dream Holiday Awaits' }}
    {%- else -%}
      {{ page_title }} — {{ shop.name }}
    {%- endif -%}
  </title>

  {%- if page_description -%}
    <meta name="description" content="{{ page_description | escape }}">
  {%- elsif settings.meta_description != blank -%}
    <meta name="description" content="{{ settings.meta_description | escape }}">
  {%- endif -%}

  {%- if settings.meta_keywords != blank -%}
    <meta name="keywords" content="{{ settings.meta_keywords | escape }}">
  {%- endif -%}

  <link rel="canonical" href="{{ canonical_url }}">

  {%- comment -%} Open Graph / Social Cards {%- endcomment -%}
  <meta property="og:site_name" content="{{ shop.name }}">
  <meta property="og:url" content="{{ canonical_url }}">
  <meta property="og:title" content="{{ page_title | escape }}">
  <meta property="og:type" content="website">
  {%- if page_description -%}
    <meta property="og:description" content="{{ page_description | escape }}">
  {%- endif -%}
  {%- if page_image -%}
    <meta property="og:image" content="https:{{ page_image | image_url: width: 1200 }}">
    <meta name="twitter:image" content="https:{{ page_image | image_url: width: 1200 }}">
  {%- elsif settings.og_image -%}
    <meta property="og:image" content="https:{{ settings.og_image | image_url: width: 1200 }}">
    <meta name="twitter:image" content="https:{{ settings.og_image | image_url: width: 1200 }}">
  {%- endif -%}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ page_title | escape }}">

  {%- comment -%} Favicon {%- endcomment -%}
  {%- if settings.favicon -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    <link rel="apple-touch-icon" href="{{ settings.favicon | image_url: width: 180, height: 180 }}">
  {%- endif -%}

  {%- comment -%} Preconnect for performance {%- endcomment -%}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

  {%- comment -%} Google Fonts — Poppins (headings) + Inter (body) {%- endcomment -%}
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Poppins:wght@600;700;800;900&display=swap"
    rel="stylesheet"
  >

  {%- comment -%} Skystar main stylesheet {%- endcomment -%}
  {{ 'skystar-custom.css' | asset_url | stylesheet_tag }}

  {%- comment -%} Shopify required tags {%- endcomment -%}
  {{ content_for_header }}

  {%- comment -%} Structured data — Organization {%- endcomment -%}
  {% render 'skystar-seo' %}
</head>

<body class="skystar-body{% if request.page_type == 'index' %} page--home{% endif %}{% if request.page_type == 'product' %} page--product{% endif %}{% if request.page_type == 'collection' %} page--collection{% endif %}">
  {%- comment -%} Skip to content for accessibility {%- endcomment -%}
  <a class="skystar-skip-link" href="#MainContent">
    Skip to content
  </a>

  {%- section 'skystar-announcement-bar' -%}
  {%- section 'skystar-header' -%}

  <main id="MainContent" class="skystar-main" role="main" tabindex="-1">
    {{ content_for_layout }}
  </main>

  {%- section 'skystar-footer' -%}

  {%- comment -%} Floating WhatsApp Button {%- endcomment -%}
  {%- liquid
    assign wa_phone = settings.whatsapp_number | default: '919999999999'
    assign wa_float_msg = settings.whatsapp_float_message | default: "Hi Skystar Tour and Travels! 👋 I'd like to know more about your tour packages."
  -%}
  <a
    href="https://wa.me/{{ wa_phone }}?text={{ wa_float_msg | url_encode }}"
    class="skystar-float-wa"
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Chat with us on WhatsApp"
    title="Chat with us on WhatsApp"
  >
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
    <span class="skystar-float-wa__tooltip">Chat with us!</span>
  </a>

  {%- comment -%} Scroll to top button {%- endcomment -%}
  <button class="skystar-scroll-top" id="skystarScrollTop" aria-label="Scroll to top">
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M7.41 15.41L12 10.83l4.59 4.58L18 14l-6-6-6 6 1.41 1.41z"/>
    </svg>
  </button>

  <script src="{{ 'skystar-custom.js' | asset_url }}" defer></script>
</body>
</html>
