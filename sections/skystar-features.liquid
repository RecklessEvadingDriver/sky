{% comment %}
  Section: skystar-features.liquid
  Trust-building features section with icons for the homepage.
  Highlights: 24/7 support, best price, verified hotels, etc.
{% endcomment %}

{%- if section.settings.show_section -%}
<section class="skystar-features">
  <div class="skystar-features__inner">
    <div class="skystar-section-header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="skystar-section-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.title != blank -%}
        <h2 class="skystar-section-title">{{ section.settings.title }}</h2>
      {%- endif -%}
      {%- if section.settings.subtitle != blank -%}
        <p class="skystar-section-subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    <div class="skystar-features__grid">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'feature_card' -%}
            <div class="skystar-feature-card" {{ block.shopify_attributes }}>
              <div class="skystar-feature-card__icon">
                {%- case block.settings.icon -%}
                  {%- when 'support' -%}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M12 1c-4.97 0-9 4.03-9 9v7c0 1.66 1.34 3 3 3h1v-8H5v-2c0-3.87 3.13-7 7-7s7 3.13 7 7v2h-2v8h1c1.66 0 3-1.34 3-3v-7c0-4.97-4.03-9-9-9z"/>
                    </svg>
                  {%- when 'price' -%}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-3.21-3.81V3h-3v2.16c-1.94.42-3.5 1.68-3.5 3.61 0 2.31 1.91 3.46 4.7 4.13 2.5.6 3 1.48 3 2.41 0 .69-.49 1.79-2.7 1.79-2.06 0-2.87-.92-2.98-2.1h-2.2c.12 2.19 1.76 3.42 3.68 3.83V21h3v-2.15c1.95-.37 3.5-1.5 3.5-3.55 0-2.84-2.43-3.81-4.7-4.4z"/>
                    </svg>
                  {%- when 'hotel' -%}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M7 13c1.66 0 3-1.34 3-3S8.66 7 7 7s-3 1.34-3 3 1.34 3 3 3zm12-6h-8v7H3V5H1v15h2v-3h18v3h2v-9c0-2.21-1.79-4-4-4z"/>
                    </svg>
                  {%- when 'visa' -%}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M14 6l-1-2H5v17h2v-7h5l1 2h7V6h-6zm4 8h-4l-1-2H7V6h5l1 2h5v6z"/>
                    </svg>
                  {%- when 'safety' -%}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-2 16l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/>
                    </svg>
                  {%- when 'whatsapp' -%}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                    </svg>
                  {%- else -%}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
                    </svg>
                {%- endcase -%}
              </div>
              {%- if block.settings.title != blank -%}
                <h3 class="skystar-feature-card__title">{{ block.settings.title }}</h3>
              {%- endif -%}
              {%- if block.settings.description != blank -%}
                <p class="skystar-feature-card__description">{{ block.settings.description }}</p>
              {%- endif -%}
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</section>
{%- endif -%}

{% schema %}
{
  "name": "Skystar Features",
  "tag": "section",
  "class": "skystar-features-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Show section",
      "default": true
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Why Choose Us"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section title",
      "default": "Your Trusted Travel Partner"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Section subtitle",
      "default": "We make every journey seamless, memorable, and worry-free."
    }
  ],
  "blocks": [
    {
      "type": "feature_card",
      "name": "Feature",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "support", "label": "24/7 Support" },
            { "value": "price", "label": "Best Price" },
            { "value": "hotel", "label": "Verified Hotels" },
            { "value": "visa", "label": "Visa Assistance" },
            { "value": "safety", "label": "Safe Travel" },
            { "value": "whatsapp", "label": "WhatsApp Booking" },
            { "value": "check", "label": "Check / Tick" }
          ],
          "default": "support"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Feature title",
          "default": "24/7 Customer Support"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Feature description",
          "default": "Our travel experts are always available to assist you before, during, and after your trip."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Skystar Features",
      "blocks": [
        {
          "type": "feature_card",
          "settings": {
            "icon": "support",
            "title": "24/7 Customer Support",
            "description": "Our travel experts are always available to assist you before, during, and after your trip."
          }
        },
        {
          "type": "feature_card",
          "settings": {
            "icon": "price",
            "title": "Best Price Guarantee",
            "description": "We match the best prices in the market. If you find it cheaper, we'll beat it."
          }
        },
        {
          "type": "feature_card",
          "settings": {
            "icon": "hotel",
            "title": "Verified Hotels & Resorts",
            "description": "Every hotel in our packages is personally inspected and guest-reviewed."
          }
        },
        {
          "type": "feature_card",
          "settings": {
            "icon": "whatsapp",
            "title": "Easy WhatsApp Booking",
            "description": "No complicated forms. Just message us on WhatsApp and we'll handle the rest."
          }
        }
      ]
    }
  ]
}
{% endschema %}
