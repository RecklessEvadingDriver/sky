{% comment %}
  Skystar List Collections Section
  Displays all available collections/tour categories
{% endcomment %}

<section class="skystar-list-collections-section">
  <div class="container">
    {% if section.settings.show_header %}
      <header class="collections-header">
        <h1 class="collections-title">{{ section.settings.heading }}</h1>
        {% if section.settings.description != blank %}
          <p class="collections-description">{{ section.settings.description }}</p>
        {% endif %}
      </header>
    {% endif %}

    <div class="collections-grid">
      {% for collection in collections %}
        {% unless collection.handle == 'frontpage' %}
          <article class="collection-card">
            <a href="{{ collection.url }}" class="collection-link">
              <div class="collection-image-wrapper">
                {% if collection.image %}
                  <img
                    src="{{ collection.image | img_url: '600x600' }}"
                    alt="{{ collection.title }}"
                    class="collection-image"
                    loading="lazy"
                  >
                {% elsif collection.products.first and collection.products.first.featured_image %}
                  <img
                    src="{{ collection.products.first.featured_image | img_url: '600x600' }}"
                    alt="{{ collection.title }}"
                    class="collection-image"
                    loading="lazy"
                  >
                {% else %}
                  <div class="collection-image-placeholder">
                    <svg width="100" height="100" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" stroke-width="2"/>
                      <circle cx="8.5" cy="8.5" r="1.5" fill="currentColor"/>
                      <path d="M21 15L16 10L5 21" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </div>
                {% endif %}
                <div class="collection-overlay"></div>
              </div>

              <div class="collection-info">
                <h2 class="collection-name">{{ collection.title }}</h2>
                <p class="collection-count">
                  {{ collection.products_count }}
                  {% if collection.products_count == 1 %}
                    {{ section.settings.product_singular }}
                  {% else %}
                    {{ section.settings.product_plural }}
                  {% endif %}
                </p>
                {% if collection.description != blank %}
                  <p class="collection-excerpt">{{ collection.description | strip_html | truncatewords: 20 }}</p>
                {% endif %}
                <span class="collection-cta">{{ section.settings.view_text }} →</span>
              </div>
            </a>
          </article>
        {% endunless %}
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .skystar-list-collections-section {
    padding: 60px 20px;
    min-height: 60vh;
  }

  .collections-header {
    text-align: center;
    margin-bottom: 60px;
  }

  .collections-title {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-text-dark, #1a1a1a);
    margin-bottom: 15px;
  }

  .collections-description {
    font-size: 1.125rem;
    color: var(--color-text-muted, #666);
    max-width: 700px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .collections-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 30px;
    max-width: 1400px;
    margin: 0 auto;
  }

  .collection-card {
    border-radius: 12px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    background-color: white;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .collection-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
  }

  .collection-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .collection-image-wrapper {
    position: relative;
    width: 100%;
    padding-bottom: 75%;
    overflow: hidden;
    background-color: var(--color-background-secondary, #f5f5f5);
  }

  .collection-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .collection-card:hover .collection-image {
    transform: scale(1.05);
  }

  .collection-image-placeholder {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-muted, #999);
  }

  .collection-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to bottom, transparent 50%, rgba(0, 0, 0, 0.3));
  }

  .collection-info {
    padding: 25px;
  }

  .collection-name {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-text-dark, #1a1a1a);
    margin-bottom: 8px;
  }

  .collection-count {
    font-size: 0.875rem;
    color: var(--color-text-muted, #666);
    margin-bottom: 12px;
  }

  .collection-excerpt {
    font-size: 0.9375rem;
    color: var(--color-text, #333);
    line-height: 1.6;
    margin-bottom: 15px;
  }

  .collection-cta {
    display: inline-block;
    color: var(--color-primary, #1e3a5f);
    font-weight: 600;
    transition: color 0.3s ease;
  }

  .collection-card:hover .collection-cta {
    color: var(--color-accent, #d4a574);
  }

  @media (max-width: 768px) {
    .collections-title {
      font-size: 2rem;
    }

    .collections-grid {
      grid-template-columns: 1fr;
      gap: 20px;
    }
  }

  @media (min-width: 769px) and (max-width: 1024px) {
    .collections-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

{% schema %}
{
  "name": "List Collections",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_header",
      "label": "Show Header",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Collections"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Explore our curated tour packages organized by destination and travel style."
    },
    {
      "type": "text",
      "id": "product_singular",
      "label": "Product Singular",
      "default": "Package"
    },
    {
      "type": "text",
      "id": "product_plural",
      "label": "Product Plural",
      "default": "Packages"
    },
    {
      "type": "text",
      "id": "view_text",
      "label": "View Collection Text",
      "default": "View Collection"
    }
  ]
}
{% endschema %}
