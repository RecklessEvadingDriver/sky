{% comment %}
  Skystar 404 Error Page Section
  Displays a user-friendly 404 error message with navigation options
{% endcomment %}

<section class="skystar-404-section">
  <div class="container">
    <div class="error-404-content">
      <div class="error-404-icon">
        <svg width="120" height="120" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/>
          <path d="M12 8V12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          <circle cx="12" cy="16" r="1" fill="currentColor"/>
        </svg>
      </div>

      <h1 class="error-404-title">{{ section.settings.heading }}</h1>
      <p class="error-404-description">{{ section.settings.description }}</p>

      <div class="error-404-actions">
        <a href="/" class="btn btn-primary">
          {{ section.settings.home_button_text }}
        </a>
        <a href="/collections/all" class="btn btn-secondary">
          {{ section.settings.browse_button_text }}
        </a>
      </div>

      {% if section.settings.show_search %}
      <div class="error-404-search">
        <form action="/search" method="get" role="search">
          <input
            type="search"
            name="q"
            placeholder="{{ section.settings.search_placeholder }}"
            class="search-input"
          >
          <button type="submit" class="search-button">
            {{ section.settings.search_button_text }}
          </button>
        </form>
      </div>
      {% endif %}
    </div>
  </div>
</section>

<style>
  .skystar-404-section {
    padding: 80px 20px;
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .error-404-content {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }

  .error-404-icon {
    color: var(--color-primary, #1e3a5f);
    margin-bottom: 30px;
  }

  .error-404-title {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-text-dark, #1a1a1a);
    margin-bottom: 15px;
  }

  .error-404-description {
    font-size: 1.125rem;
    color: var(--color-text-muted, #666);
    margin-bottom: 30px;
    line-height: 1.6;
  }

  .error-404-actions {
    display: flex;
    gap: 15px;
    justify-content: center;
    margin-bottom: 40px;
    flex-wrap: wrap;
  }

  .error-404-actions .btn {
    padding: 12px 30px;
    font-size: 1rem;
    text-decoration: none;
    border-radius: 4px;
    transition: all 0.3s ease;
  }

  .error-404-actions .btn-primary {
    background-color: var(--color-primary, #1e3a5f);
    color: white;
    border: 2px solid var(--color-primary, #1e3a5f);
  }

  .error-404-actions .btn-primary:hover {
    background-color: transparent;
    color: var(--color-primary, #1e3a5f);
  }

  .error-404-actions .btn-secondary {
    background-color: transparent;
    color: var(--color-primary, #1e3a5f);
    border: 2px solid var(--color-primary, #1e3a5f);
  }

  .error-404-actions .btn-secondary:hover {
    background-color: var(--color-primary, #1e3a5f);
    color: white;
  }

  .error-404-search {
    margin-top: 40px;
  }

  .error-404-search form {
    display: flex;
    gap: 10px;
    max-width: 400px;
    margin: 0 auto;
  }

  .error-404-search .search-input {
    flex: 1;
    padding: 12px 20px;
    border: 2px solid var(--color-border, #e0e0e0);
    border-radius: 4px;
    font-size: 1rem;
  }

  .error-404-search .search-button {
    padding: 12px 25px;
    background-color: var(--color-primary, #1e3a5f);
    color: white;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    font-size: 1rem;
    transition: background-color 0.3s ease;
  }

  .error-404-search .search-button:hover {
    background-color: var(--color-primary-dark, #152b47);
  }

  @media (max-width: 768px) {
    .error-404-title {
      font-size: 2rem;
    }

    .error-404-actions {
      flex-direction: column;
      align-items: stretch;
    }

    .error-404-search form {
      flex-direction: column;
    }
  }
</style>

{% schema %}
{
  "name": "404 Error Page",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Page Not Found"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Sorry, we couldn't find the page you're looking for. It may have been moved or no longer exists."
    },
    {
      "type": "text",
      "id": "home_button_text",
      "label": "Home Button Text",
      "default": "Back to Home"
    },
    {
      "type": "text",
      "id": "browse_button_text",
      "label": "Browse Button Text",
      "default": "Browse Packages"
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "Show Search Bar",
      "default": true
    },
    {
      "type": "text",
      "id": "search_placeholder",
      "label": "Search Placeholder",
      "default": "Search for tours..."
    },
    {
      "type": "text",
      "id": "search_button_text",
      "label": "Search Button Text",
      "default": "Search"
    }
  ],
  "presets": [
    {
      "name": "404 Error Page"
    }
  ]
}
{% endschema %}
