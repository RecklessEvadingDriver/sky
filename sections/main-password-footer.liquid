{% comment %}
  Skystar Password Page Footer
  Footer for password-protected store
{% endcomment %}

<footer class="password-footer">
  <div class="container">
    <p class="password-footer-text">
      {{ section.settings.footer_text }}
    </p>
    <p class="password-footer-powered">
      Powered by Shopify
    </p>
  </div>
</footer>

<style>
  .password-footer {
    padding: 30px 20px;
    text-align: center;
    background-color: white;
    border-top: 1px solid var(--color-border, #e0e0e0);
    margin-top: 60px;
  }

  .password-footer-text {
    font-size: 0.9375rem;
    color: var(--color-text-muted, #666);
    margin-bottom: 10px;
  }

  .password-footer-powered {
    font-size: 0.875rem;
    color: var(--color-text-muted, #999);
  }
</style>

{% schema %}
{
  "name": "Password Footer",
  "settings": [
    {
      "type": "text",
      "id": "footer_text",
      "label": "Footer Text",
      "default": "© 2024 Skystar Tour and Travels. All rights reserved."
    }
  ]
}
{% endschema %}
