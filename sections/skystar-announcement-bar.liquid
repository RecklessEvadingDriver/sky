{%- comment -%}
  Section: skystar-announcement-bar.liquid
  Configurable top announcement/promo bar.
  Can be dismissed by the user (stored in sessionStorage).
{%- endcomment -%}

{%- if section.settings.show_bar and section.settings.text != blank -%}
<div
  class="skystar-announcement-bar"
  id="skystarAnnouncementBar"
  role="region"
  aria-label="Announcement"
  style="background-color: {{ section.settings.bg_color }}; color: {{ section.settings.text_color }};"
>
  <div class="skystar-announcement-bar__inner">
    {%- if section.settings.icon != blank -%}
      <span class="skystar-announcement-bar__icon">{{ section.settings.icon }}</span>
    {%- endif -%}

    <p class="skystar-announcement-bar__text">
      {{ section.settings.text }}
      {%- if section.settings.link != blank and section.settings.link_text != blank -%}
        &nbsp;—&nbsp;
        <a href="{{ section.settings.link }}" style="color: {{ section.settings.link_color }};" class="skystar-announcement-bar__link">
          {{ section.settings.link_text }} →
        </a>
      {%- endif -%}
    </p>

    {%- if section.settings.dismissible -%}
      <button
        class="skystar-announcement-bar__close"
        id="skystarAnnouncementClose"
        aria-label="Dismiss announcement"
        style="color: {{ section.settings.text_color }};"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
        </svg>
      </button>
    {%- endif -%}
  </div>
</div>

<script>
(function () {
  var bar = document.getElementById('skystarAnnouncementBar');
  var closeBtn = document.getElementById('skystarAnnouncementClose');

  if (!bar) return;

  // Hide if already dismissed this session
  if (sessionStorage.getItem('skystar_ann_closed')) {
    bar.style.display = 'none';
  }

  if (closeBtn) {
    closeBtn.addEventListener('click', function () {
      bar.style.maxHeight = bar.scrollHeight + 'px';
      requestAnimationFrame(function () {
        bar.style.transition = 'max-height 0.3s ease, opacity 0.3s ease';
        bar.style.maxHeight = '0';
        bar.style.opacity = '0';
        setTimeout(function () { bar.style.display = 'none'; }, 350);
      });
      sessionStorage.setItem('skystar_ann_closed', '1');
    });
  }
})();
</script>
{%- endif -%}

{% schema %}
{
  "name": "Announcement Bar",
  "tag": "div",
  "class": "skystar-announcement-bar-wrapper",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_bar",
      "label": "Show announcement bar",
      "default": true
    },
    {
      "type": "text",
      "id": "icon",
      "label": "Emoji / icon prefix",
      "default": "✈️"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Announcement text",
      "default": "Book your dream holiday today! Free itinerary planning with every booking."
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "Link text",
      "default": "Explore Packages"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link URL"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#0a2d6e"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Link color",
      "default": "#f5a623"
    },
    {
      "type": "checkbox",
      "id": "dismissible",
      "label": "Allow users to dismiss",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar"
    }
  ]
}
{% endschema %}
