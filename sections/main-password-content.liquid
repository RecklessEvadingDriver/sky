{% comment %}
  Skystar Password Page Content
  Main content area for password-protected store
{% endcomment %}

<main class="password-main">
  <div class="container">
    <div class="password-content">
      {% if section.settings.image %}
        <div class="password-image">
          <img src="{{ section.settings.image | img_url: '800x' }}" alt="{{ shop.name }}" loading="lazy">
        </div>
      {% endif %}

      <div class="password-form-wrapper">
        <h1 class="password-title">{{ section.settings.heading }}</h1>

        {% if section.settings.message != blank %}
          <div class="password-message">
            {{ section.settings.message }}
          </div>
        {% endif %}

        {% form 'storefront_password' %}
          {{ form.errors | default_errors }}

          <div class="password-form">
            <label for="password" class="visually-hidden">Password</label>
            <input
              type="password"
              name="password"
              id="password"
              class="password-input"
              placeholder="{{ section.settings.password_placeholder }}"
              autofocus
            >
            <button type="submit" name="commit" class="password-button">
              {{ section.settings.button_text }}
            </button>
          </div>
        {% endform %}

        {% if shop.password_message != blank %}
          <div class="password-admin-message">
            {{ shop.password_message }}
          </div>
        {% endif %}

        {% if section.settings.show_social %}
          <div class="password-social">
            <p class="password-social-heading">{{ section.settings.social_heading }}</p>
            <div class="password-social-links">
              {% if settings.social_facebook_link != blank %}
                <a href="{{ settings.social_facebook_link }}" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                </a>
              {% endif %}
              {% if settings.social_instagram_link != blank %}
                <a href="{{ settings.social_instagram_link }}" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
                </a>
              {% endif %}
              {% if settings.social_twitter_link != blank %}
                <a href="{{ settings.social_twitter_link }}" target="_blank" rel="noopener noreferrer" aria-label="X (Twitter)">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                </a>
              {% endif %}
            </div>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</main>

<style>
  .password-main {
    min-height: 60vh;
    display: flex;
    align-items: center;
    padding: 60px 20px;
    background: linear-gradient(135deg, var(--color-background, #f8f9fa) 0%, var(--color-background-secondary, #fff) 100%);
  }

  .password-content {
    max-width: 1000px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }

  .password-image img {
    width: 100%;
    border-radius: 12px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
  }

  .password-form-wrapper {
    max-width: 450px;
  }

  .password-title {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-text-dark, #1a1a1a);
    margin-bottom: 20px;
    line-height: 1.2;
  }

  .password-message {
    font-size: 1.125rem;
    color: var(--color-text, #333);
    margin-bottom: 30px;
    line-height: 1.6;
  }

  .password-form {
    display: flex;
    gap: 10px;
    margin-bottom: 20px;
  }

  .password-input {
    flex: 1;
    padding: 15px 20px;
    border: 2px solid var(--color-border, #e0e0e0);
    border-radius: 4px;
    font-size: 1rem;
    transition: border-color 0.3s ease;
  }

  .password-input:focus {
    outline: none;
    border-color: var(--color-primary, #1e3a5f);
  }

  .password-button {
    padding: 15px 30px;
    background-color: var(--color-primary, #1e3a5f);
    color: white;
    border: none;
    border-radius: 4px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }

  .password-button:hover {
    background-color: var(--color-primary-dark, #152b47);
  }

  .password-admin-message {
    padding: 15px;
    background-color: var(--color-background-secondary, #f5f5f5);
    border-radius: 4px;
    margin-bottom: 30px;
    font-size: 0.9375rem;
    color: var(--color-text-muted, #666);
  }

  .password-social {
    text-align: center;
    margin-top: 40px;
    padding-top: 30px;
    border-top: 1px solid var(--color-border, #e0e0e0);
  }

  .password-social-heading {
    font-size: 1rem;
    color: var(--color-text-muted, #666);
    margin-bottom: 15px;
  }

  .password-social-links {
    display: flex;
    justify-content: center;
    gap: 15px;
  }

  .password-social-links a {
    color: var(--color-text-muted, #666);
    transition: color 0.3s ease;
  }

  .password-social-links a:hover {
    color: var(--color-primary, #1e3a5f);
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  .errors {
    color: var(--color-error, #d32f2f);
    margin-bottom: 20px;
    padding: 15px;
    background-color: #ffebee;
    border-radius: 4px;
  }

  @media (max-width: 768px) {
    .password-content {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .password-title {
      font-size: 2rem;
    }

    .password-form {
      flex-direction: column;
    }
  }
</style>

{% schema %}
{
  "name": "Password Content",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Opening Soon"
    },
    {
      "type": "richtext",
      "id": "message",
      "label": "Message",
      "default": "<p>We're preparing something amazing! Enter the password to get early access.</p>"
    },
    {
      "type": "text",
      "id": "password_placeholder",
      "label": "Password Placeholder",
      "default": "Enter password"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Enter"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Show Social Links",
      "default": true
    },
    {
      "type": "text",
      "id": "social_heading",
      "label": "Social Heading",
      "default": "Follow us for updates"
    }
  ]
}
{% endschema %}
