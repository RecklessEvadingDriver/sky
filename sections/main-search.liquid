{% comment %}
  Skystar Main Search Section
  Displays search results for products, collections, and pages
{% endcomment %}

<section class="skystar-search-section">
  <div class="container">
    <div class="search-header">
      <h1 class="search-title">{{ section.settings.heading }}</h1>

      <form action="/search" method="get" role="search" class="search-form">
        <input
          type="search"
          name="q"
          value="{{ search.terms | escape }}"
          placeholder="{{ section.settings.search_placeholder }}"
          class="search-input"
          autofocus
        >
        <button type="submit" class="search-button">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="2"/>
            <path d="M21 21L16.65 16.65" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
          {{ section.settings.search_button_text }}
        </button>
      </form>
    </div>

    {% if search.performed %}
      <div class="search-results">
        {% if search.results_count > 0 %}
          <p class="search-results-count">
            {{ search.results_count }}
            {% if search.results_count == 1 %}
              {{ section.settings.result_singular }}
            {% else %}
              {{ section.settings.result_plural }}
            {% endif %}
            {% if search.terms %}
              for "{{ search.terms }}"
            {% endif %}
          </p>

          <div class="search-results-grid">
            {% for item in search.results %}
              {% case item.object_type %}
                {% when 'product' %}
                  <article class="search-result-card product-card">
                    <a href="{{ item.url }}" class="result-link">
                      <div class="result-image">
                        {% if item.featured_image %}
                          <img
                            src="{{ item.featured_image | img_url: '400x400' }}"
                            alt="{{ item.title }}"
                            loading="lazy"
                          >
                        {% else %}
                          <div class="result-image-placeholder">No image</div>
                        {% endif %}
                      </div>
                      <div class="result-content">
                        <span class="result-type">Package</span>
                        <h3 class="result-title">{{ item.title }}</h3>
                        {% if item.price %}
                          <p class="result-price">Starting from {{ item.price | money }}</p>
                        {% endif %}
                        {% if item.description != blank %}
                          <p class="result-excerpt">{{ item.description | strip_html | truncatewords: 20 }}</p>
                        {% endif %}
                      </div>
                    </a>
                  </article>

                {% when 'collection' %}
                  <article class="search-result-card collection-card">
                    <a href="{{ item.url }}" class="result-link">
                      <div class="result-image">
                        {% if item.image %}
                          <img
                            src="{{ item.image | img_url: '400x400' }}"
                            alt="{{ item.title }}"
                            loading="lazy"
                          >
                        {% elsif item.products.first and item.products.first.featured_image %}
                          <img
                            src="{{ item.products.first.featured_image | img_url: '400x400' }}"
                            alt="{{ item.title }}"
                            loading="lazy"
                          >
                        {% else %}
                          <div class="result-image-placeholder">No image</div>
                        {% endif %}
                      </div>
                      <div class="result-content">
                        <span class="result-type">Collection</span>
                        <h3 class="result-title">{{ item.title }}</h3>
                        <p class="result-meta">{{ item.products_count }} packages</p>
                        {% if item.description != blank %}
                          <p class="result-excerpt">{{ item.description | strip_html | truncatewords: 20 }}</p>
                        {% endif %}
                      </div>
                    </a>
                  </article>

                {% when 'page' %}
                  <article class="search-result-card page-card">
                    <a href="{{ item.url }}" class="result-link">
                      <div class="result-content result-content-full">
                        <span class="result-type">Page</span>
                        <h3 class="result-title">{{ item.title }}</h3>
                        {% if item.content != blank %}
                          <p class="result-excerpt">{{ item.content | strip_html | truncatewords: 30 }}</p>
                        {% endif %}
                      </div>
                    </a>
                  </article>
              {% endcase %}
            {% endfor %}
          </div>

          {% if paginate.pages > 1 %}
            <div class="search-pagination">
              {% if paginate.previous %}
                <a href="{{ paginate.previous.url }}" class="pagination-link pagination-prev">
                  ← Previous
                </a>
              {% endif %}

              {% for part in paginate.parts %}
                {% if part.is_link %}
                  <a href="{{ part.url }}" class="pagination-link">{{ part.title }}</a>
                {% else %}
                  <span class="pagination-current">{{ part.title }}</span>
                {% endif %}
              {% endfor %}

              {% if paginate.next %}
                <a href="{{ paginate.next.url }}" class="pagination-link pagination-next">
                  Next →
                </a>
              {% endif %}
            </div>
          {% endif %}
        {% else %}
          <div class="search-no-results">
            <div class="no-results-icon">
              <svg width="100" height="100" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="2"/>
                <path d="M21 21L16.65 16.65" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                <path d="M8 11H14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              </svg>
            </div>
            <h2>{{ section.settings.no_results_heading }}</h2>
            <p>{{ section.settings.no_results_message }}</p>
            <a href="/collections/all" class="btn btn-primary">
              {{ section.settings.browse_button_text }}
            </a>
          </div>
        {% endif %}
      </div>
    {% endif %}
  </div>
</section>

<style>
  .skystar-search-section {
    padding: 60px 20px;
    min-height: 60vh;
  }

  .search-header {
    max-width: 800px;
    margin: 0 auto 50px;
    text-align: center;
  }

  .search-title {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-text-dark, #1a1a1a);
    margin-bottom: 30px;
  }

  .search-form {
    display: flex;
    gap: 10px;
  }

  .search-input {
    flex: 1;
    padding: 15px 20px;
    border: 2px solid var(--color-border, #e0e0e0);
    border-radius: 4px;
    font-size: 1rem;
    transition: border-color 0.3s ease;
  }

  .search-input:focus {
    outline: none;
    border-color: var(--color-primary, #1e3a5f);
  }

  .search-button {
    padding: 15px 30px;
    background-color: var(--color-primary, #1e3a5f);
    color: white;
    border: none;
    border-radius: 4px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: background-color 0.3s ease;
  }

  .search-button:hover {
    background-color: var(--color-primary-dark, #152b47);
  }

  .search-results-count {
    font-size: 1.125rem;
    color: var(--color-text-muted, #666);
    margin-bottom: 30px;
    text-align: center;
  }

  .search-results-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 30px;
    max-width: 1400px;
    margin: 0 auto;
  }

  .search-result-card {
    border-radius: 12px;
    overflow: hidden;
    background-color: white;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .search-result-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 6px 16px rgba(0, 0, 0, 0.15);
  }

  .result-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .result-image {
    width: 100%;
    padding-bottom: 75%;
    position: relative;
    background-color: var(--color-background-secondary, #f5f5f5);
    overflow: hidden;
  }

  .result-image img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .result-image-placeholder {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-muted, #999);
  }

  .result-content {
    padding: 20px;
  }

  .result-content-full {
    padding: 25px;
  }

  .result-type {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    color: var(--color-primary, #1e3a5f);
    background-color: rgba(30, 58, 95, 0.1);
    padding: 4px 10px;
    border-radius: 4px;
    margin-bottom: 10px;
  }

  .result-title {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-text-dark, #1a1a1a);
    margin-bottom: 8px;
    line-height: 1.3;
  }

  .result-price {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-primary, #1e3a5f);
    margin-bottom: 10px;
  }

  .result-meta {
    font-size: 0.9375rem;
    color: var(--color-text-muted, #666);
    margin-bottom: 10px;
  }

  .result-excerpt {
    font-size: 0.9375rem;
    color: var(--color-text, #333);
    line-height: 1.6;
  }

  .search-no-results {
    text-align: center;
    padding: 80px 20px;
    max-width: 600px;
    margin: 0 auto;
  }

  .no-results-icon {
    color: var(--color-text-muted, #999);
    margin-bottom: 30px;
  }

  .search-no-results h2 {
    font-size: 2rem;
    margin-bottom: 15px;
  }

  .search-no-results p {
    font-size: 1.125rem;
    color: var(--color-text-muted, #666);
    margin-bottom: 30px;
  }

  .search-no-results .btn {
    padding: 15px 40px;
    background-color: var(--color-primary, #1e3a5f);
    color: white;
    text-decoration: none;
    border-radius: 4px;
    display: inline-block;
    transition: background-color 0.3s ease;
  }

  .search-no-results .btn:hover {
    background-color: var(--color-primary-dark, #152b47);
  }

  .search-pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 10px;
    margin-top: 60px;
  }

  .pagination-link,
  .pagination-current {
    padding: 10px 15px;
    border: 1px solid var(--color-border, #e0e0e0);
    border-radius: 4px;
    text-decoration: none;
    color: var(--color-text, #333);
    transition: all 0.3s ease;
  }

  .pagination-link:hover {
    background-color: var(--color-primary, #1e3a5f);
    color: white;
    border-color: var(--color-primary, #1e3a5f);
  }

  .pagination-current {
    background-color: var(--color-primary, #1e3a5f);
    color: white;
    border-color: var(--color-primary, #1e3a5f);
  }

  @media (max-width: 768px) {
    .search-title {
      font-size: 2rem;
    }

    .search-form {
      flex-direction: column;
    }

    .search-results-grid {
      grid-template-columns: 1fr;
      gap: 20px;
    }
  }
</style>

{% schema %}
{
  "name": "Main Search",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Search"
    },
    {
      "type": "text",
      "id": "search_placeholder",
      "label": "Search Placeholder",
      "default": "Search for tours, destinations..."
    },
    {
      "type": "text",
      "id": "search_button_text",
      "label": "Search Button Text",
      "default": "Search"
    },
    {
      "type": "text",
      "id": "result_singular",
      "label": "Result Singular",
      "default": "result"
    },
    {
      "type": "text",
      "id": "result_plural",
      "label": "Result Plural",
      "default": "results"
    },
    {
      "type": "text",
      "id": "no_results_heading",
      "label": "No Results Heading",
      "default": "No results found"
    },
    {
      "type": "textarea",
      "id": "no_results_message",
      "label": "No Results Message",
      "default": "Try adjusting your search terms or browse our tour packages."
    },
    {
      "type": "text",
      "id": "browse_button_text",
      "label": "Browse Button Text",
      "default": "Browse All Packages"
    }
  ]
}
{% endschema %}
