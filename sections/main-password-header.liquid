{% comment %}
  Skystar Password Page Header
  Header for password-protected store
{% endcomment %}

<header class="password-header">
  <div class="container">
    <div class="password-logo">
      {% if section.settings.logo %}
        <img src="{{ section.settings.logo | img_url: '200x' }}" alt="{{ shop.name }}" class="logo-image">
      {% else %}
        <h1 class="store-name">{{ shop.name }}</h1>
      {% endif %}
    </div>
  </div>
</header>

<style>
  .password-header {
    padding: 30px 20px;
    text-align: center;
    background-color: white;
    border-bottom: 1px solid var(--color-border, #e0e0e0);
  }

  .password-logo .logo-image {
    max-width: 200px;
    height: auto;
  }

  .password-logo .store-name {
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-primary, #1e3a5f);
    margin: 0;
  }
</style>

{% schema %}
{
  "name": "Password Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    }
  ]
}
{% endschema %}
