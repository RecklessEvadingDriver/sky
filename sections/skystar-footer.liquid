{%- comment -%}
  Section: skystar-footer.liquid
  Full production-ready footer with:
    • Logo + brand description
    • Quick links column (up to 6 links)
    • Contact info column (address, phone, email, hours)
    • Social media icons (fully admin-configurable)
    • Newsletter signup (links to email)
    • Copyright bar with policy links
{%- endcomment -%}

{%- liquid
  assign wa_phone = settings.whatsapp_number | default: '919999999999'
-%}

<footer class="skystar-footer" role="contentinfo">
  <div class="skystar-footer__main">
    <div class="skystar-footer__inner">

      {%- comment -%}<!-- ── COL 1: Brand ── -->{%- endcomment -%}
      <div class="skystar-footer__col skystar-footer__col--brand">
        {%- if section.settings.logo -%}
          <a href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
            <img
              src="{{ section.settings.logo | image_url: height: 56 }}"
              alt="{{ shop.name }}"
              height="56"
              loading="lazy"
              class="skystar-footer__logo"
            >
          </a>
        {%- else -%}
          <a href="{{ routes.root_url }}" class="skystar-footer__brand-name">
            {{ settings.store_name | default: shop.name }}
          </a>
        {%- endif -%}

        {%- if section.settings.description != blank -%}
          <p class="skystar-footer__brand-desc">{{ section.settings.description }}</p>
        {%- endif -%}

        {%- comment -%} Social icons {%- endcomment -%}
        {% render 'social-icons', context: 'footer' %}

        {%- if section.settings.show_whatsapp_badge -%}
          {%- liquid
            assign wa_footer_msg = section.settings.whatsapp_message | default: "Hi Skystar! I'd like to know more about your tour packages."
          -%}
          <a
            href="https://wa.me/{{ wa_phone }}?text={{ wa_footer_msg | url_encode }}"
            class="skystar-footer__wa-badge"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            {{ section.settings.whatsapp_badge_text | default: 'Chat on WhatsApp' }}
          </a>
        {%- endif -%}
      </div>

      {%- comment -%}<!-- ── COL 2: Quick Links ── -->{%- endcomment -%}
      <div class="skystar-footer__col">
        <h3 class="skystar-footer__col-title">{{ section.settings.links_title | default: 'Quick Links' }}</h3>
        <ul class="skystar-footer__link-list" role="list">
          {%- for i in (1..6) -%}
            {%- liquid
              assign link_text = 'quick_link_' | append: i | append: '_text'
              assign link_url  = 'quick_link_' | append: i | append: '_url'
              assign text_val  = section.settings[link_text]
              assign url_val   = section.settings[link_url]
            -%}
            {%- if text_val != blank and url_val != blank -%}
              <li>
                <a href="{{ url_val }}" class="skystar-footer__link">{{ text_val }}</a>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </div>

      {%- comment -%}<!-- ── COL 3: Contact Info ── -->{%- endcomment -%}
      <div class="skystar-footer__col">
        <h3 class="skystar-footer__col-title">{{ section.settings.contact_title | default: 'Contact Us' }}</h3>
        <ul class="skystar-footer__contact-list" role="list">
          {%- if section.settings.address != blank -%}
            <li class="skystar-footer__contact-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
              </svg>
              <span>{{ section.settings.address }}</span>
            </li>
          {%- endif -%}

          {%- if section.settings.phone != blank -%}
            <li class="skystar-footer__contact-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
              </svg>
              <a href="tel:{{ section.settings.phone | remove: ' ' | remove: '-' }}" class="skystar-footer__link">{{ section.settings.phone }}</a>
            </li>
          {%- endif -%}

          {%- if section.settings.email != blank -%}
            <li class="skystar-footer__contact-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
              </svg>
              <a href="mailto:{{ section.settings.email }}" class="skystar-footer__link">{{ section.settings.email }}</a>
            </li>
          {%- endif -%}

          {%- if section.settings.hours != blank -%}
            <li class="skystar-footer__contact-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67V7z"/>
              </svg>
              <span>{{ section.settings.hours }}</span>
            </li>
          {%- endif -%}
        </ul>
      </div>

      {%- comment -%}<!-- ── COL 4: Newsletter ── -->{%- endcomment -%}
      {%- if section.settings.show_newsletter -%}
        <div class="skystar-footer__col">
          <h3 class="skystar-footer__col-title">{{ section.settings.newsletter_title | default: 'Stay Updated' }}</h3>
          <p class="skystar-footer__newsletter-desc">{{ section.settings.newsletter_desc | default: 'Get the best travel deals and holiday inspiration straight to your inbox.' }}</p>
          <form
            class="skystar-footer__newsletter-form"
            action="{{ routes.root_url }}"
            method="get"
            onsubmit="return skystarNewsletterSubmit(this);"
          >
            <div class="skystar-footer__newsletter-input-group">
              <input
                type="email"
                name="email"
                id="footerEmail"
                placeholder="{{ section.settings.newsletter_placeholder | default: 'Your email address' }}"
                required
                autocomplete="email"
                class="skystar-footer__newsletter-input"
                aria-label="Email address"
              >
              <button type="submit" class="skystar-footer__newsletter-btn" aria-label="Subscribe">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/>
                </svg>
              </button>
            </div>
          </form>
          <p class="skystar-footer__newsletter-note">{{ section.settings.newsletter_note | default: 'No spam, ever. Unsubscribe anytime.' }}</p>
        </div>
      {%- endif -%}

    </div>
  </div>

  {%- comment -%}<!-- ── BOTTOM BAR ── -->{%- endcomment -%}
  <div class="skystar-footer__bottom">
    <div class="skystar-footer__bottom-inner">
      <p class="skystar-footer__copyright">
        © {{ 'now' | date: '%Y' }} {{ shop.name }}. {{ section.settings.copyright_extra | default: 'All rights reserved.' }}
      </p>
      <nav class="skystar-footer__policy-nav" aria-label="Policy links">
        {%- if shop.privacy_policy -%}
          <a href="{{ shop.privacy_policy.url }}" class="skystar-footer__policy-link">Privacy Policy</a>
        {%- endif -%}
        {%- if shop.terms_of_service -%}
          <a href="{{ shop.terms_of_service.url }}" class="skystar-footer__policy-link">Terms of Service</a>
        {%- endif -%}
        {%- if shop.refund_policy -%}
          <a href="{{ shop.refund_policy.url }}" class="skystar-footer__policy-link">Cancellation Policy</a>
        {%- endif -%}
      </nav>
    </div>
  </div>
</footer>

<script>
function skystarNewsletterSubmit(form) {
  var email = form.email.value;
  if (!email) return false;
  // Open WhatsApp with email lead
  var wa_phone = '{{ wa_phone }}';
  var msg = 'Hi Skystar! I\'d like to subscribe for travel deals. My email is: ' + email;
  window.open('https://wa.me/' + wa_phone + '?text=' + encodeURIComponent(msg), '_blank');
  form.reset();
  return false;
}
</script>

{% schema %}
{
  "name": "Footer",
  "tag": "footer",
  "class": "skystar-footer-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Brand Column"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Footer logo",
      "info": "White/light version recommended on dark footer"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Brand description",
      "default": "Skystar Tour and Travels — your trusted travel partner for domestic, international, and honeymoon packages. Let us craft your perfect holiday."
    },
    {
      "type": "checkbox",
      "id": "show_whatsapp_badge",
      "label": "Show WhatsApp badge",
      "default": true
    },
    {
      "type": "text",
      "id": "whatsapp_badge_text",
      "label": "WhatsApp badge text",
      "default": "Chat on WhatsApp"
    },
    {
      "type": "text",
      "id": "whatsapp_message",
      "label": "WhatsApp pre-filled message",
      "default": "Hi Skystar! I'd like to know more about your tour packages."
    },
    {
      "type": "header",
      "content": "Quick Links Column"
    },
    {
      "type": "text",
      "id": "links_title",
      "label": "Column title",
      "default": "Quick Links"
    },
    {
      "type": "text",
      "id": "quick_link_1_text",
      "label": "Link 1 text",
      "default": "Home"
    },
    {
      "type": "url",
      "id": "quick_link_1_url",
      "label": "Link 1 URL",
      "default": "/"
    },
    {
      "type": "text",
      "id": "quick_link_2_text",
      "label": "Link 2 text",
      "default": "Domestic Tours"
    },
    {
      "type": "url",
      "id": "quick_link_2_url",
      "label": "Link 2 URL"
    },
    {
      "type": "text",
      "id": "quick_link_3_text",
      "label": "Link 3 text",
      "default": "International Tours"
    },
    {
      "type": "url",
      "id": "quick_link_3_url",
      "label": "Link 3 URL"
    },
    {
      "type": "text",
      "id": "quick_link_4_text",
      "label": "Link 4 text",
      "default": "Honeymoon Packages"
    },
    {
      "type": "url",
      "id": "quick_link_4_url",
      "label": "Link 4 URL"
    },
    {
      "type": "text",
      "id": "quick_link_5_text",
      "label": "Link 5 text",
      "default": "About Us"
    },
    {
      "type": "url",
      "id": "quick_link_5_url",
      "label": "Link 5 URL",
      "default": "/pages/about"
    },
    {
      "type": "text",
      "id": "quick_link_6_text",
      "label": "Link 6 text",
      "default": "Contact Us"
    },
    {
      "type": "url",
      "id": "quick_link_6_url",
      "label": "Link 6 URL",
      "default": "/pages/contact"
    },
    {
      "type": "header",
      "content": "Contact Column"
    },
    {
      "type": "text",
      "id": "contact_title",
      "label": "Column title",
      "default": "Contact Us"
    },
    {
      "type": "text",
