[
  {
    "name": "theme_info",
    "theme_name": "Skystar Tour and Travels",
    "theme_version": "2.0.0",
    "theme_author": "Skystar Tour and Travels",
    "theme_documentation_url": "https://shopify.dev/docs/themes",
    "theme_support_url": "https://shopify.dev/docs/themes"
  },
  {
    "name": "Brand Identity",
    "settings": [
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon",
        "info": "16×16px or 32×32px .png recommended"
      },
      {
        "type": "text",
        "id": "store_name",
        "label": "Store / brand name",
        "default": "Skystar Tour and Travels"
      },
      {
        "type": "text",
        "id": "store_tagline",
        "label": "Brand tagline",
        "default": "Your Dream Holiday Awaits"
      },
      {
        "type": "image_picker",
        "id": "og_image",
        "label": "Default social sharing image",
        "info": "Shown when your homepage is shared on social media. Recommended 1200×630px."
      }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "color_primary",
        "label": "Primary brand color (navy)",
        "default": "#0a2d6e",
        "info": "Used for header, headings, and UI elements"
      },
      {
        "type": "color",
        "id": "color_secondary",
        "label": "Accent color (gold)",
        "default": "#f5a623",
        "info": "Used for badges, highlights, and call-to-actions"
      },
      {
        "type": "color",
        "id": "color_text",
        "label": "Body text color",
        "default": "#1a1a2e"
      },
      {
        "type": "color",
        "id": "color_bg",
        "label": "Page background color",
        "default": "#ffffff"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "select",
        "id": "font_heading",
        "label": "Heading font",
        "options": [
          { "value": "Poppins", "label": "Poppins (Recommended)" },
          { "value": "Montserrat", "label": "Montserrat" },
          { "value": "Raleway", "label": "Raleway" },
          { "value": "Playfair Display", "label": "Playfair Display" },
          { "value": "Georgia", "label": "Georgia (System)" }
        ],
        "default": "Poppins"
      },
      {
        "type": "select",
        "id": "font_body",
        "label": "Body font",
        "options": [
          { "value": "Inter", "label": "Inter (Recommended)" },
          { "value": "Lato", "label": "Lato" },
          { "value": "Open Sans", "label": "Open Sans" },
          { "value": "Nunito", "label": "Nunito" },
          { "value": "system-ui", "label": "System Default" }
        ],
        "default": "Inter"
      },
      {
        "type": "range",
        "id": "font_size_base",
        "label": "Base font size (px)",
        "min": 14,
        "max": 18,
        "step": 1,
        "default": 16
      }
    ]
  },
  {
    "name": "Skystar — WhatsApp",
    "settings": [
      {
        "type": "text",
        "id": "whatsapp_number",
        "label": "WhatsApp phone number",
        "info": "Enter the full number with country code, no spaces or symbols. Example: 919876543210 (for +91-98765-43210)",
        "placeholder": "919999999999"
      },
      {
        "type": "text",
        "id": "whatsapp_float_message",
        "label": "Floating button pre-filled message",
        "default": "Hi Skystar Tour and Travels! 👋 I'd like to know more about your tour packages."
      }
    ]
  },
  {
    "name": "Contact Information",
    "settings": [
      {
        "type": "text",
        "id": "contact_phone",
        "label": "Primary phone number",
        "placeholder": "+91 98765 43210"
      },
      {
        "type": "text",
        "id": "contact_email",
        "label": "Email address",
        "placeholder": "hello@skystartravel.com"
      },
      {
        "type": "textarea",
        "id": "contact_address",
        "label": "Office address",
        "placeholder": "123, Travel House, MG Road, Bengaluru — 560001"
      },
      {
        "type": "text",
        "id": "contact_hours",
        "label": "Office hours",
        "default": "Mon–Sat: 9am – 7pm"
      }
    ]
  },
  {
    "name": "Social Media",
    "settings": [
      {
        "type": "url",
        "id": "social_facebook",
        "label": "Facebook page URL"
      },
      {
        "type": "url",
        "id": "social_instagram",
        "label": "Instagram profile URL"
      },
      {
        "type": "url",
        "id": "social_youtube",
        "label": "YouTube channel URL"
      },
      {
        "type": "url",
        "id": "social_twitter",
        "label": "X (Twitter) profile URL"
      },
      {
        "type": "url",
        "id": "social_linkedin",
        "label": "LinkedIn page URL"
      },
      {
        "type": "url",
        "id": "social_pinterest",
        "label": "Pinterest profile URL"
      }
    ]
  },
  {
    "name": "SEO",
    "settings": [
      {
        "type": "textarea",
        "id": "meta_description",
        "label": "Default meta description",
        "info": "Used on pages without a specific description. Keep under 160 characters.",
        "default": "Skystar Tour and Travels — premium holiday packages for domestic, international & honeymoon travel. Book via WhatsApp today!"
      },
      {
        "type": "text",
        "id": "meta_keywords",
        "label": "Meta keywords (comma-separated)",
        "default": "tour packages, travel agency, holiday packages, domestic tours, international tours, honeymoon packages, Skystar"
      }
    ]
  }
]
